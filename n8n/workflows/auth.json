    {
      "id": "16",
      "name": "Generate JWT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        60
      ],
      "parameters": {
        "jsCode": "const header = { alg: 'HS256', typ: 'JWT' };\nconst now = Math.floor(Date.now() / 1000);\nconst payload = {\n  sub: $input.first().json.id,\n  email: $input.first().json.email,\n  role: $input.first().json.role,\n  department_id: $input.first().json.primary_department_id || null,\n  iat: now,\n  exp: now + 86400,\n};\n\nconst secret = 'helpdesk-jwt-secret-dev-2026';\n\nfunction base64url(str) {\n  return Buffer.from(str).toString('base64url');\n}\n\nconst headerB64 = base64url(JSON.stringify(header));\nconst payloadB64 = base64url(JSON.stringify(payload));\nconst signature = require('crypto')\n  .createHmac('sha256', secret)\n  .update(`${headerB64}.${payloadB64}`)\n  .digest('base64url');\n\nconst token = `${headerB64}.${payloadB64}.${signature}`;\n\nreturn [{\n  json: {\n    success: true,\n    token,\n    user: {\n      id: $input.first().json.id,\n      email: $input.first().json.email,\n      full_name: $input.first().json.full_name,\n      role: $input.first().json.role,\n      department: $input.first().json.department || null,\n    }\n  }\n}];"
      }
    },
    {
      "id": "17",
      "name": "Respond Login Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1660,
        60
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {
          "responseCode": 200
        }
      }
    },
    {
      "id": "18",
      "name": "Webhook Verify",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -980,
        520
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "auth/verify",
        "responseMode": "responseNode",
        "options": {}
      },
      "webhookId": "auth-verify-webhook"
    },
    {
      "id": "19",
      "name": "Verify JWT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -760,
        520
      ],
      "parameters": {
        "jsCode": "const token = $input.first().json.body?.token;\nconst secret = 'helpdesk-jwt-secret-dev-2026';\n\ntry {\n  if (!token || typeof token !== 'string') throw new Error('Invalid token');\n\n  const parts = token.split('.');\n  if (parts.length !== 3) throw new Error('Invalid token');\n\n  const headerB64 = parts[0];\n  const payloadB64 = parts[1];\n  const signatureB64 = parts[2];\n\n  const expectedSig = require('crypto')\n    .createHmac('sha256', secret)\n    .update(`${headerB64}.${payloadB64}`)\n    .digest('base64url');\n\n  if (signatureB64 !== expectedSig) throw new Error('Invalid signature');\n\n  const payload = JSON.parse(Buffer.from(payloadB64, 'base64url').toString());\n\n  if (payload.exp < Math.floor(Date.now() / 1000)) throw new Error('Token expired');\n\n  return [{ json: { success: true, user: payload } }];\n} catch (e) {\n  return [{ json: { success: false, error: 'Token invalid sau expirat.' } }];\n}"
      }
    },
    {
      "id": "20",
      "name": "Respond Verify",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        -540,
        520
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {
          "responseCode": 200
        }
      }
    }

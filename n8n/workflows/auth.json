      "id": "13",
      "name": "Build User With Department",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        -40
      ],
      "parameters": {
        "jsCode": "return [{\n  json: {\n    id: $json.id,\n    email: $json.email,\n    full_name: $json.full_name,\n    role: $json.role,\n    primary_department_id: $json.primary_department_id,\n    department: ($json.dept_id !== undefined && $json.dept_id !== null)\n      ? { id: $json.dept_id, name: $json.dept_name, color: $json.dept_color }\n      : null\n  }\n}];"
      }
    },
    {
      "id": "14",
      "name": "Build User Without Department",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        160
      ],
      "parameters": {
        "jsCode": "return [{\n  json: {\n    id: $json.id,\n    email: $json.email,\n    full_name: $json.full_name,\n    role: $json.role,\n    primary_department_id: $json.primary_department_id || null,\n    department: null\n  }\n}];"
      }
    },
    {
      "id": "15",
      "name": "User Ready",
      "type": "n8n-nodes-base.merge",

      "id": "1",
      "name": "Webhook Login",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -980,
        120
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "auth/login",
        "responseMode": "responseNode",
        "options": {}
      },
      "webhookId": "auth-login-webhook"
    },
    {
      "id": "2",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -760,
        120
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst email = typeof body.email === 'string' ? body.email.trim().toLowerCase() : '';\nconst password = typeof body.password === 'string' ? body.password : '';\n\nif (!email || !password) {\n  return [{\n    json: {\n      success: false,\n      error: 'Email și parola sunt obligatorii.'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    email,\n    password\n  }\n}];"
      }
    },
    {
      "id": "3",
      "name": "Input Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -540,
        120
      ],
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.success}}",
              "value2": true
            }
          ]
        }
      }
    },
    {
      "id": "4",
      "name": "Respond Missing Input",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        -320,
        280
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {
          "responseCode": 400
        }
      }
    },
    {
      "id": "5",
      "name": "Query User",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        -320,
        60
      ],
      "alwaysOutputData": true,
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, email, full_name, role, primary_department_id, is_active,\n       password_hash,\n       (password_hash = crypt($1, password_hash)) as password_valid\nFROM users\nWHERE email = $2 AND is_active = true\nLIMIT 1",
        "additionalFields": {
          "queryParams": "={{$json.password}},{{$json.email}}"
        }
      },
      "credentials": {
        "postgres": {
          "name": "Helpdesk PostgreSQL"
        }
      }
    },
    {
